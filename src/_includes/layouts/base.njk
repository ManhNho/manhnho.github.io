<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {# ---- client-side security hardening (static host can't set HTTP headers) ---- #}
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests">
  <meta name="referrer" content="strict-origin-when-cross-origin">

  {% set isPost = (ogType == "article") %}
  {# ---- canonical + language alternates ---- #}
  {% set canonical = site.url + page.url %}
  {% if lang == "en" %}{% set altUrl = site.url + "/vi" + page.url %}{% else %}{% set altUrl = site.url + (page.url | replace("/vi/", "/")) %}{% endif %}

  {# ---- SEO title (tab/SERP only) ---- #}
  {% if isPost %}{% set pageTitle = title + " · ManhNho (Pham Tien Manh)" %}
  {% elif title %}{% set pageTitle = title + " · ManhNho — Pham Tien Manh" %}
  {% else %}{% set pageTitle = "ManhNho (Pham Tien Manh) — Bug Bounty Hunter, Red Teamer & CyPeace CEO" %}{% endif %}
  {% set metaDesc = description or site.person.description %}
  {% set ogImage = site.url + "/assets/img/acropolis/portrait.jpg" %}
  {% set ogTypeVal = ogType or "website" %}

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ metaDesc }}">
  <meta name="keywords" content="{{ site.keywords }}">
  <meta name="author" content="{{ site.person.name }} (ManhNho)">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <link rel="canonical" href="{{ canonical }}">
  <link rel="alternate" hreflang="{{ 'en' if lang == 'en' else 'vi' }}" href="{{ canonical }}">
  <link rel="alternate" hreflang="{{ 'vi' if lang == 'en' else 'en' }}" href="{{ altUrl }}">
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ page.url }}">

  {# ---- Open Graph ---- #}
  <meta property="og:type" content="{{ ogTypeVal }}">
  <meta property="og:site_name" content="ManhNho — Pham Tien Manh">
  <meta property="og:locale" content="{{ 'en_US' if lang == 'en' else 'vi_VN' }}">
  <meta property="og:locale:alternate" content="{{ 'vi_VN' if lang == 'en' else 'en_US' }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ metaDesc }}">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:image" content="{{ ogImage }}">
  <meta property="og:image:alt" content="Pham Tien Manh (ManhNho)">
  {% if isPost %}
  <meta property="article:published_time" content="{{ page.date | isoDate }}">
  <meta property="article:author" content="{{ site.person.name }}">
  {% for tag in tags_list %}<meta property="article:tag" content="{{ tag }}">{% endfor %}
  {% endif %}

  {# ---- Twitter ---- #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ metaDesc }}">
  <meta name="twitter:image" content="{{ ogImage }}">
  <meta name="twitter:creator" content="@manhnho95">

  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/assets/img/favicon.svg">
  <link rel="alternate" type="application/rss+xml" title="ManhNho — Blog" href="{{ site.url }}{{ '/feed.xml' if lang == 'en' else '/vi/feed.xml' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Playfair+Display:wght@700;800;900&family=DM+Sans:wght@400;500;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/main.css">
  <noscript><style>.reveal{opacity:1 !important;transform:none !important}</style></noscript>

  {# ---- JSON-LD structured data ---- #}
  {% if isPost %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ title | dump | safe }},
    "description": {{ metaDesc | dump | safe }},
    "datePublished": "{{ page.date | isoDate }}",
    "dateModified": "{{ page.date | isoDate }}",
    "inLanguage": "{{ lang }}",
    "image": "{{ ogImage }}",
    "keywords": {{ (tags_list or []) | dump | safe }},
    "url": "{{ canonical }}",
    "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ canonical }}" },
    "author": { "@type": "Person", "name": "{{ site.person.name }}", "alternateName": "ManhNho", "url": "{{ site.url }}/" },
    "publisher": { "@type": "Person", "name": "{{ site.person.name }}", "url": "{{ site.url }}/" }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "{{ site.url }}{{ '/blog/' if lang == 'en' else '/vi/blog/' }}" },
      { "@type": "ListItem", "position": 3, "name": {{ title | dump | safe }}, "item": "{{ canonical }}" }
    ]
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "{{ site.person.name }}",
    "alternateName": {{ site.person.alternateName | dump | safe }},
    "url": "{{ site.url }}/",
    "image": "{{ site.person.image }}",
    "jobTitle": "{{ site.person.jobTitle }}",
    "nationality": "{{ site.person.nationality }}",
    "description": {{ site.person.description | dump | safe }},
    "worksFor": { "@type": "Organization", "name": "{{ site.person.worksFor }}", "url": "https://cypeace.net" },
    "alumniOf": { "@type": "CollegeOrUniversity", "name": "{{ site.person.alumniOf }}" },
    "knowsAbout": {{ site.person.knowsAbout | dump | safe }},
    "sameAs": {{ site.person.sameAs | dump | safe }}
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "ManhNho — Pham Tien Manh",
    "url": "{{ site.url }}/",
    "inLanguage": "{{ lang }}",
    "author": { "@type": "Person", "name": "{{ site.person.name }}" },
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "{{ site.url }}/blog/?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  {% endif %}
</head>
<body>
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="scanline" aria-hidden="true"></div>

  {% set homeUrl = "/" if lang == "en" else "/vi/" %}
  {% set blogUrl = "/blog/" if lang == "en" else "/vi/blog/" %}
  {% if lang == "en" %}
    {% set otherUrl = "/vi" + page.url %}
  {% else %}
    {% set otherUrl = page.url | replace("/vi/", "/") %}
  {% endif %}

  <header class="site-header">
    <nav class="nav container">
      <a class="brand" href="{{ homeUrl }}"><span class="prompt">~$</span> manhnho<span class="cursor">▊</span></a>
      <div class="nav-links">
        <a href="{{ homeUrl }}" {% if page.url == homeUrl %}class="active"{% endif %}>{{ t[lang].nav_home }}</a>
        <a href="{{ blogUrl }}" {% if "blog" in page.url %}class="active"{% endif %}>{{ t[lang].nav_blog }}</a>
        <a class="lang-switch" href="{{ otherUrl }}" title="Switch language">{{ t[lang].switch_lang }}</a>
      </div>
    </nav>
  </header>

  <main class="container">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-social">
        <a href="{{ site.social.github }}" target="_blank" rel="noopener">GitHub</a>
        <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener">LinkedIn</a>
        <a href="{{ site.social.acropolis }}" target="_blank" rel="noopener">Synack Acropolis</a>
        <a href="{{ site.social.company }}" target="_blank" rel="noopener">CyPeace</a>
      </div>
      <p class="footer-note">© {% year %} Pham Tien Manh</p>
    </div>
  </footer>

  <script src="/assets/js/main.js" defer></script>
</body>
</html>
